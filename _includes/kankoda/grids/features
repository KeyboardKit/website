<div class="grid features col3">
  {% for feature in include.features %}
  <a href="{{ feature.url }}{{ include.anchor }}" class="{{feature.class}}">
    <div class="image-container rounded glass scale">
      {%- if feature.emoji -%}
      <span class="emoji">{{feature.emoji}}</span>
      {%- else -%}
      <img src="{{ feature.image }}" alt="{{ feature.title }} icon" title="{{ feature.title }}" />
      {%- endif -%}
      {%- if feature.tags -%}
        {% assign tags = feature.tags | split: " " %}
        {% assign first_tag = tags[0] %}
        <span class="tag {{first_tag}}">{{first_tag}}</span>
      {%- endif -%}
    </div>
    <div>
      <h3>{{ feature.title }}</h3>
      <p>{{ feature.text }}</p>
    </div>
  </a>
  {% endfor %}
</div>