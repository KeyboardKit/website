<div class="slide-in feature-box{% if include.delay %} delay-{{include.delay}}{% endif %}">
  <h3>{{ include.title }}</h3>
  <img src="{{ include.image }}" alt="{{ include.title }} feature" />
  <p>
    {{ include.text }}
  </p>
  {% if include.cta_link %}
  <div class="cta-container">
    <a class="cta secondary" href="{{ include.cta_link }}">
      {% if include.cta_text %}{{ include.cta_text }}{% else %}Learn more{% endif %}
    </a>
  </div>
  {% endif %}
</div>
